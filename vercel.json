{
  "buildCommand": "npm run build",
  "outputDirectory": "out",
  "framework": null,
  "redirects": [
    {
      "source": "/blog/best-digital-banks-philippines-2026",
      "destination": "/blog/best-digital-banks-philippines",
      "permanent": true
    },
    {
      "source": "/blog/bir-withholding-tax-table-2026-explained",
      "destination": "/government/bir/withholding-tax-table-philippines",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
